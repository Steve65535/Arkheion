{
  "description": "FSCA CLI - 链上智能合约集群开发工具",
  "commands": {
    "init": {
      "description": "初始化 FSCA 项目",
      "handler": "./libs/commands/init/init",
      "usage": "fsca init [--networkName <name>] [--rpc <url>] [--chainId <id>] [--blockConfirmations <num>] [--accountPrivateKey <key>] [--address <addr>]",
      "params": {
        "networkName": {
          "type": "string",
          "required": false,
          "description": "网络名称"
        },
        "rpc": {
          "type": "string",
          "required": false,
          "description": "RPC URL"
        },
        "chainId": {
          "type": "number",
          "required": false,
          "description": "链 ID"
        },
        "blockConfirmations": {
          "type": "number",
          "required": false,
          "description": "区块确认数"
        },
        "accountPrivateKey": {
          "type": "string",
          "required": false,
          "description": "账户私钥"
        },
        "address": {
          "type": "string",
          "required": false,
          "description": "钱包地址"
        }
      }
    },
    "cluster": {
      "description": "FSCA 集群相关命令",
      "commands": {
        "init": {
          "description": "部署 FSCA 集群",
          "handler": "./libs/commands/cluster/init",
          "usage": "fsca cluster init [--threshold <num>]",
          "params": {
            "threshold": {
              "type": "number",
              "required": false,
              "description": "多签钱包所需确认数（默认：1）"
            }
          }
        }
      }
    }

  }
}
