{
  "description": "FSCA CLI - 链上智能合约集群开发工具",
  "commands": {
    "chain": {
      "description": "链相关命令",
      "commands": {
        "info": {
          "description": "显示链信息",
          "handler": "./libs/chain/info",
          "usage": "fsca chain info"
        },
        "balance": {
          "description": "查询余额",
          "handler": "./libs/chain/balance",
          "params": {
            "address": {
              "type": "string",
              "required": true,
              "description": "地址"
            }
          },
          "usage": "fsca chain balance --address 0x..."
        }
      }
    },
    "wallet": {
      "description": "钱包相关命令",
      "commands": {
        "create": {
          "description": "创建新钱包",
          "handler": "./libs/wallet/create",
          "usage": "fsca wallet create"
        },
        "import": {
          "description": "导入钱包",
          "handler": "./libs/wallet/import",
          "params": {
            "privateKey": {
              "type": "string",
              "required": true,
              "description": "私钥"
            }
          },
          "usage": "fsca wallet import --privateKey 0x..."
        }
      }
    },
    "init": {
      "description": "初始化 FSCA 项目",
      "handler": "./libs/commands/init/init",
      "usage": "fsca init [--networkName <name>] [--rpc <url>] [--chainId <id>] [--blockConfirmations <num>] [--accountPrivateKey <key>] [--address <addr>]",
      "params": {
        "networkName": {
          "type": "string",
          "required": false,
          "description": "网络名称"
        },
        "rpc": {
          "type": "string",
          "required": false,
          "description": "RPC URL"
        },
        "chainId": {
          "type": "number",
          "required": false,
          "description": "链 ID"
        },
        "blockConfirmations": {
          "type": "number",
          "required": false,
          "description": "区块确认数"
        },
        "accountPrivateKey": {
          "type": "string",
          "required": false,
          "description": "账户私钥"
        },
        "address": {
          "type": "string",
          "required": false,
          "description": "钱包地址"
        }
      }
    },
    "version": {
      "description": "显示版本信息",
      "handler": "./libs/version",
      "usage": "fsca version"
    }
  }
}
